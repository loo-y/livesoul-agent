OCR_CONFIDENCE_THRESHOLD=0.8
VISION_TIMEOUT_SECONDS=300
SCREENSHOT_INTERVAL=0.5
AUTO_SELECT_REGION=true
SCREENSHOT_BACKEND=auto
SCREENSHOT_MONITOR=1
SCREENSHOT_IMAGE_PATH=

VISION_API_KEY=
VISION_MODEL_NAME=gpt-4.1-mini
VISION_API_BASE=https://api.openai.com/v1

LLM_API_KEY=
LLM_MODEL_NAME=gpt-4.1-mini
LLM_API_BASE=https://api.openai.com/v1

# TTS provider switch:
# - console
# - pyttsx3
# - edge
# - openai
# - minimaxi
# - siliconflow
TTS_PROVIDER=minimaxi
TTS_API_KEY=
TTS_MODEL_NAME=speech-2.8-turbo
TTS_API_ENDPOINT=https://api.minimaxi.com/v1/t2a_v2
TTS_VOICE=female-shaonv-jingpin
TTS_RESPONSE_FORMAT=mp3
TTS_SAMPLE_RATE=32000
TTS_STREAM=false
TTS_SPEED=1
TTS_GAIN=0
TTS_OUTPUT_DIR=runtime/audio

# SiliconFlow example:
# TTS_PROVIDER=siliconflow
# TTS_API_KEY=
# TTS_MODEL_NAME=FunAudioLLM/CosyVoice2-0.5B
# TTS_API_ENDPOINT=https://api.siliconflow.cn/v1/audio/speech
# TTS_VOICE=susu
# TTS_RESPONSE_FORMAT=mp3
# TTS_SAMPLE_RATE=44100
# TTS_STREAM=false
# TTS_SPEED=1
# TTS_GAIN=0

MEMORY_DIR=runtime/memory
AGENT_CONFIG_DIR=agent_config
LOG_LEVEL=INFO
DEDUP_WINDOW_SECONDS=8
QUEUE_MAXSIZE=50
