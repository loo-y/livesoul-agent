OCR_CONFIDENCE_THRESHOLD=0.8
SCREENSHOT_INTERVAL=0.5
AUTO_SELECT_REGION=true
SCREENSHOT_BACKEND=auto
SCREENSHOT_MONITOR=1
SCREENSHOT_IMAGE_PATH=

VISION_API_KEY=
VISION_MODEL_NAME=gpt-4.1-mini
VISION_API_BASE=https://api.openai.com/v1

LLM_API_KEY=
LLM_MODEL_NAME=gpt-4.1-mini
LLM_API_BASE=https://api.openai.com/v1

TTS_PROVIDER=console
TTS_API_KEY=
TTS_MODEL_NAME=gpt-4o-mini-tts
TTS_API_BASE=https://api.openai.com/v1
TTS_VOICE=alloy
TTS_OUTPUT_DIR=runtime/audio

AGENT_CONFIG_DIR=agent_config
LOG_LEVEL=INFO
DEDUP_WINDOW_SECONDS=8
QUEUE_MAXSIZE=50
